rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /shipments/{shipmentId} {

      allow read: if true;

      allow write:
        if request.auth != null;

      match /events/{eventId} {
        allow read: if true;

        allow write:
          if request.auth != null;
      }
    }
  }
}